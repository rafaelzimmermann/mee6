# WhatsApp configuration for agntrick-whatsapp.
# Copy to ~/.config/agntrick/whatsapp.yaml and fill in your values.

channel:
  storage_path: ~/.config/agntrick/whatsapp   # neonize session data

privacy:
  allowed_contact: "+34612345678"   # E.164 — only messages from this number are processed
  log_filtered_messages: false

features:
  text_messages: true
  media_messages: true
  group_messages: false
  presence_updates: true
  typing_indicators: true

whatsapp_bridge:
  auto_setup: true
  auto_connect: true
  bridge_timeout_sec: 180
  poll_interval_sec: 1.0

# Optional: audio transcription via Groq (requires ffmpeg + GROQ_AUDIO_API_KEY env var)
# audio_transcriber:
#   model: whisper-large-v3-turbo
#   timeout: 60.0
