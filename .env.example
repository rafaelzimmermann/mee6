# Global agntrick configuration — copy to ~/.config/agntrick/.env
# This file is shared across all agntrick-based projects.

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Ollama — mee6 does not run Ollama itself, it connects to your existing server
OLLAMA_BASE_URL=http://192.168.1.x:11434
OLLAMA_DEFAULT_MODEL=llama3

# Override the directory where agntrick looks for global config (whatsapp.yaml, etc.)
# Defaults to ~/.config/agntrick — only set this if you use a non-standard location.
# AGNTRICK_CONFIG_DIR=~/.config/agntrick
