# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Ollama — mee6 does not run Ollama itself, it connects to your existing server
OLLAMA_BASE_URL=http://192.168.1.x:11434
OLLAMA_DEFAULT_MODEL=llama3

# School app credentials
SCHOOL_APP_URL=https://your-school-app.example.com
SCHOOL_APP_USERNAME=your_username
SCHOOL_APP_PASSWORD=your_password

# WhatsApp notification target (E.164 format)
NOTIFY_PHONE_NUMBER=+34612345678

# WhatsApp channel storage path (neonize session data)
WHATSAPP_STORAGE_PATH=./data/whatsapp

# Google Calendar
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_CREDENTIALS_FILE=/app/data/credentials.json
